      "special": [
        "Assault",
        "Fist",
        "Agile",
        "Faster",
        "Open-topped",
        {
          "name": "Synaptic Relay",
          "description": "If at least one Flood Officer is alive, this unit extends that officer’s command bubble to Flood Infantry and Artillery within 6\" of it, but with the morale bonus halved. For normal morale checks, affected units use the highest officer’s morale bonus available (halved). For Snap To via this relay, only the activating officer’s halved morale bonus is used, even if another officer on the field has a higher bonus."
        }
      ],
      "isFloodBorrowed": false,
      "sourceFaction": null,
      "originalName": "Juggernaut",
