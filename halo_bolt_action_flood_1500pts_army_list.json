    {
      "name": "Carrier Form Team",
      "type": "Team",
      "veterancy": "Regular",
      "men": 1,
      "damageValue": "",
      "weapons": [
        {
          "name": "Explosive Biomass"
        }
      ],
      "special": [
        "Tank Hunters",
        "Infiltrator",
        "Horror",
        {
          "name": "Suicide Charge",
          "description": "If this model successfully assaults an enemy unit and makes contact, it is immediately removed, and the assaulted unit suffers a HE (2\") hit."
        },
        {
          "name": "Explosive Biomass",
          "description": "If this model is destroyed (by shooting, assault, or other means), immediately place a 2\" HE template centered on its final position. Resolve hits against all units under the template, friend or foe."
        },
        {
          "name": "Spawn Infection Forms",
          "description": "When this unit is destroyed, immediately replace the model with a new unit of 1D3 Inexperienced Infection Forms. Place them as close as possible to the position where the Carrier Form was destroyed, while remaining at least 1\" away from any other units. These Infection Forms lose all pins and use the same Order Die the unit had. If there is not enough space to place them all, place as many as possible."
        },
        {
          "name": "Extra Selection",
          "description": "You may take up to 3 Carrier Form Teams as a single choice in any platoon selector that allows an Anti-Tank Team. This does not prevent you from also taking a standard Anti-Tank Team."
        }
      ],
      "isFloodBorrowed": false,
      "sourceFaction": null,
      "originalName": "Carrier Form Team",
      "cost": 20,
      "weaponsTable": [
        {
          "qty": 1,
          "label": "Explosive Biomass",
          "range": "–",
          "shots": "–",
          "pen": "HE",
          "special": "Suicide Charge, HE (2\")"
        }
      ],
      "doctrine": null,
      "extraDoctrineUpgrades": {}
    },
